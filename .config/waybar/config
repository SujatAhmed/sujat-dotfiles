{
  "layer": "top",	
    "position": "top",
    "height": 24,


    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": [],
    "modules-right": ["network", "backlight", "pulseaudio", "battery", "clock", "tray"],


    "hyprland/workspaces": {
      "disable-scroll": true,
      "disable-markup": true,
      "format": "{name}" 
    },


    "hyprland/window": {
      "format": "{}",
      "max-length": 150
    },


    "tray": {
      "icon-size": 15,
      "spacing": 10 
    },


    "clock": {
      "format": "{:%a %b %e  %R}",
      "interval": 30
    },



    "battery": {
      "interval": 10,
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format-time": "{H}:{M:02}",
      "format": "{icon} {capacity}%({time})",
      "format-charging": "{capacity}%({time})",
      "format-charging-full": "{capacity}%",
      "format-full": "{icon} {capacity}%",
      "format-alt": "{icon} {power}W",
      "format-icons": [
        " " ,
      "",
      "",
      "",
      ""
      ],
      "tooltip": false
    },


    "network": {
      "interval": 5,
      "format-wifi": " {essid}({signalStrength}%)",
      "format-ethernet": " {ifname}",
      "format-disconnected": "No connection",
      "format-alt": " {ipaddr}/{cidr}",
      "tooltip": false
    },




    "backlight": {
      "device": "intel_backlight",
      "format": "{icon} {percent}%  ",

      "format-icons": ["", ""],
      "interval": 60
    },


    "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-bluetooth": "{icon} {volume}%",
      "format-muted": "",
      "format-icons": {
        "headphone": " ",
        "hands-free": "",
        "headset": "",
        "phone": "",
        "portable": "",
        "car": "",
        "default": ["", ""]
      },
      "scroll-step": 1,
      "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
      "tooltip": false
    }
}


